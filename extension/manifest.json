{
  "manifest_version": 3,
  "name": "Knox CRM",
  "version": "1.4.1",
  "description": "Add contacts and log emails to Knox CRM from Gmail",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:3001/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Knox CRM Settings"
  }
}
